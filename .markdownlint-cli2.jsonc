{
  // Rule set lives in .markdownlint.jsonc (auto-discovered and merged).
  // This file only configures markdownlint-cli2 ignores.
  //
  // OpenSpec generates instruction files under .claude/skills/openspec-*/ and
  // .claude/commands/opsx/ via `openspec init`/`openspec update`. They are
  // regenerated by the CLI, so hand-fixing lint here would be overwritten.
  // OpenSpec change files under openspec/changes/** use a `## ...`-first
  // convention (no top-level H1) that conflicts with MD041, and are authored and
  // managed through the OpenSpec workflow. Exclude all of these from linting.
  //
  // bin/ and obj/ hold build output (e.g. a Playwright-bundled README.md),
  // node_modules/ holds bun-installed front-end dependencies, and tmp/ holds
  // gitignored scratch files; none are source we lint.
  "ignores": [
    ".claude/skills/openspec-*/**",
    ".claude/commands/opsx/**",
    "openspec/changes/**",
    "openspec/specs/**",
    "**/bin/**",
    "**/obj/**",
    "**/node_modules/**",
    "tmp/**"
  ]
}
