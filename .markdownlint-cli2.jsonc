{
  // Rule set lives in .markdownlint.jsonc (auto-discovered and merged).
  // This file only configures markdownlint-cli2 ignores.
  //
  // OpenSpec generates instruction files under these paths via
  // `openspec init`/`openspec update`. They are regenerated by the CLI, so
  // hand-fixing lint here would be overwritten. Exclude them from linting.
  "ignores": [
    ".claude/skills/openspec-*/**",
    ".claude/commands/opsx/**"
  ]
}
