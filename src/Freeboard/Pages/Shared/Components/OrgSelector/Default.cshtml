@using Freeboard.Pages.Shared.Components.OrgSelector
@model OrgSelectorViewModel
@{
    ViewData["OrgSelectorReturn"] = Uri.EscapeDataString(Model.ReturnTarget);
    ViewData["OrgSelectorSelectedId"] = Model.SelectedId;
    var allSelected = Model.SelectedId is null;
    var allHref = $"/org/select?return={ViewData["OrgSelectorReturn"]}";
}
<p class="nav-section-title" id="org-selector-heading">Organisation</p>
<ul class="space-y-0.5 text-sm" aria-labelledby="org-selector-heading">
    <li>
        <a href="@allHref" class="@(allSelected ? "nav-link nav-link-active" : "nav-link")"
           aria-current="@(allSelected ? "true" : null)">
            All Organisations
            @if (allSelected)
            {
                <span class="sr-only">(current selection)</span>
            }
        </a>
    </li>
    @foreach (var root in Model.Roots)
    {
        <partial name="~/Pages/Shared/Components/OrgSelector/_Node.cshtml" model="root" />
    }
</ul>
