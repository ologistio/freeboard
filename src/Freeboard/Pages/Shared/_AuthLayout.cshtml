        <header class="mb-6">
            <a href="/" class="flex items-center gap-2" aria-label="Freeboard home">
                <span class="fb-mark" aria-hidden="true">F</span>
                <span class="fb-name">Freeboard</span>
            </a>
        </header>
        <main class="w-full max-w-md rounded-lg border border-line bg-panel px-6 py-8 sm:px-10"
              style="box-shadow: var(--shadow-md)">
            @RenderBody()
        </main>
    </div>
</body>
</html>
