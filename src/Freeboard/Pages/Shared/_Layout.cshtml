@{
    var name = User.FindFirst(AuthClaims.Name)?.Value;
    var email = User.FindFirst(AuthClaims.Email)?.Value;
    var role = User.FindFirst(AuthClaims.Role)?.Value;
    var isAdmin = string.Equals(role, GlobalRoles.Admin, StringComparison.OrdinalIgnoreCase);
    var displayName = string.IsNullOrWhiteSpace(name) ? "Account" : name;
    var initials = Initials(name);
}
@functions {
    private bool IsActive(string href)
    {
        var path = (Context.Request.Path.Value ?? "/").ToLowerInvariant();
        return path == href || path.StartsWith(href + "/", StringComparison.Ordinal);
    }

    private string NavClass(string href) => IsActive(href) ? "nav-link nav-link-active" : "nav-link";

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return string.Empty;
        }

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        var first = char.ToUpperInvariant(parts[0][0]);
        return parts.Length == 1
            ? first.ToString()
            : $"{first}{char.ToUpperInvariant(parts[^1][0])}";
    }
}
<!DOCTYPE html>
<html lang="en">
<partial name="_Head" />
<body class="min-h-screen bg-neutral-50 font-sans text-neutral-900">
<div x-data="{ nav: false }" class="min-h-screen">
    <div x-show="nav" x-cloak x-transition.opacity @@click="nav = false"
         class="fixed inset-0 z-30 bg-black/40 lg:hidden"></div>

    <aside class="fixed inset-y-0 left-0 z-40 flex w-64 flex-col border-r border-neutral-200 bg-white transition-transform lg:translate-x-0"
           :class="nav ? 'translate-x-0' : '-translate-x-full'">
        <a href="/home" class="flex h-14 shrink-0 items-center gap-2 border-b border-neutral-200 px-4 text-brand">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="2" y="3" width="20" height="18" rx="3" fill="currentColor" />
                <rect x="5" y="7" width="6" height="4" rx="1" fill="#ffffff" />
                <rect x="13" y="7" width="6" height="4" rx="1" fill="#ffffff" fill-opacity="0.55" />
                <rect x="5" y="13" width="14" height="4" rx="1" fill="#ffffff" fill-opacity="0.55" />
            </svg>
            <span class="text-lg font-bold tracking-tight">Freeboard</span>
        </a>
        <nav aria-label="Main" class="flex-1 space-y-1 overflow-y-auto p-3">
            <a href="/home" class="@NavClass("/home")">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75" />
                </svg>
                Home
            </a>

            <p class="nav-section-title">Compliance</p>
            <a href="/compliance/statement-of-applicability" class="@NavClass("/compliance")">
                <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
                </svg>
                Statement of Applicability
            </a>

            @if (isAdmin)
            {
                <p class="nav-section-title">Admin</p>
                <a href="/admin/users" class="@NavClass("/admin")">
                    <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
                    </svg>
                    Users
                </a>
            }
        </nav>
    </aside>

    <div class="lg:pl-64">
        <header class="sticky top-0 z-20 flex h-14 items-center gap-2 border-b border-neutral-200 bg-white/95 px-4 backdrop-blur">
            <button type="button" @@click="nav = true"
                    class="-ml-1 rounded-md p-2 text-neutral-600 hover:bg-neutral-100 lg:hidden" aria-label="Open navigation">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </button>
            <div class="flex-1"></div>

            <div x-data="{ menu: false }" class="relative">
                <button type="button" @@click="menu = !menu" @@click.outside="menu = false"
                        class="flex items-center gap-2 rounded-md px-2 py-1.5 text-sm hover:bg-neutral-100">
                    <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand text-xs font-semibold text-white">
                        @if (string.IsNullOrEmpty(initials))
                        {
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                            </svg>
                        }
                        else
                        {
                            @initials
                        }
                    </span>
                    <span class="hidden max-w-[10rem] truncate font-medium sm:inline">@displayName</span>
                    <svg class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                </button>
                <div x-show="menu" x-cloak x-transition
                     class="absolute right-0 mt-1 w-64 overflow-hidden rounded-md border border-neutral-200 bg-white py-1 shadow-lg">
                    <div class="flex items-start justify-between gap-2 border-b border-neutral-100 px-4 py-3">
                        <div class="min-w-0">
                            <p class="truncate text-sm font-semibold">@displayName</p>
                            @if (!string.IsNullOrWhiteSpace(email))
                            {
                                <p class="truncate text-xs text-neutral-600">@email</p>
                            }
                        </div>
                        <span class="badge badge-brand shrink-0 capitalize">@(role ?? "member")</span>
                    </div>
                    <a href="/account" class="menu-item">Account</a>
                    <a href="/account/mfa" class="menu-item">Security</a>
                    <a href="/account/sessions" class="menu-item">Sessions</a>
                    <form method="post" action="/logout" asp-antiforgery="true" class="border-t border-neutral-100">
                        <button type="submit" class="menu-item">Sign out</button>
                    </form>
                </div>
            </div>
        </header>

        <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
            @RenderBody()
        </main>
    </div>
</div>
</body>
</html>
