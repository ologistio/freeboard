@page "/admin/usercredential"
@model Freeboard.Pages.Admin.UserCredentialModel
@{
    ViewData["Title"] = "Temporary password";
}
<h1>Temporary password</h1>
@if (!string.IsNullOrEmpty(Model.TemporaryPassword))
{
    <p class="success">Give this temporary password to the user now - it is shown only once. They must change it on first sign-in.</p>
    <p class="temp-password">@Model.TemporaryPassword</p>
}
else
{
    <p>There is no temporary password to show. It is displayed only once, right after it is generated.</p>
}
<p><a href="/admin/users">Back to users</a></p>
