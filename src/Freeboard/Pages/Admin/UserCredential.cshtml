@page "/settings/usercredential"
@model Freeboard.Pages.Admin.UserCredentialModel
@{
    ViewData["Title"] = "Temporary password";
    ViewData["NavGroup"] = "Platform";
    ViewData["NavItem"] = "users";
    ViewData["BreadcrumbParent"] = "Users";
    ViewData["BreadcrumbParentHref"] = "/settings/users";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Temporary password</h1>
    <p class="mt-1 text-sm text-muted">Hand this to the new user - it is shown only once.</p>
</div>
@if (!string.IsNullOrEmpty(Model.TemporaryPassword))
{
    <p class="notice success max-w-md">Give this temporary password to the user now - it is shown only once. They must change it on first sign-in.</p>
    <div class="card mt-4 max-w-md">
        <p class="temp-password font-mono text-lg break-all">@Model.TemporaryPassword</p>
    </div>
}
else
{
    <p class="notice max-w-md">There is no temporary password to show. It is displayed only once, right after it is generated.</p>
}
<p class="mt-6 text-sm"><a class="link" href="/settings/users">Back to users</a></p>
