@page "/admin/usercredential"
@model Freeboard.Pages.Admin.UserCredentialModel
@{
    ViewData["Title"] = "Temporary password";
}
<h1 class="text-2xl font-bold">Temporary password</h1>
@if (!string.IsNullOrEmpty(Model.TemporaryPassword))
{
    <p class="success my-3">Give this temporary password to the user now - it is shown only once. They must change it on first sign-in.</p>
    <p class="temp-password my-3 break-all">@Model.TemporaryPassword</p>
}
else
{
    <p class="my-3">There is no temporary password to show. It is displayed only once, right after it is generated.</p>
}
<p class="my-3"><a class="text-[#215091] underline" href="/admin/users">Back to users</a></p>
