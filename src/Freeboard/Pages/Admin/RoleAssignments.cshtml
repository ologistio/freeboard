@page "/settings/role-assignments"
@model Freeboard.Pages.Admin.RoleAssignmentsModel
@{
    ViewData["Title"] = "Role assignments";
    ViewData["NavGroup"] = "Platform";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Role assignments</h1>
    <p class="mt-1 text-sm text-neutral-600">Grant and revoke organisation roles.</p>
</div>

@if (Model.Notice is not null)
{
    <p class="notice mb-4 max-w-2xl">@Model.Notice</p>
}

<form method="get" class="mb-6 flex max-w-md gap-2">
    <input type="text" name="orgId" value="@Model.OrgId" placeholder="Organisation id" class="form-input" />
    <button type="submit" class="btn-primary">Load</button>
</form>

@if (!string.IsNullOrEmpty(Model.OrgId))
{
    <div class="card mb-6 max-w-3xl overflow-x-auto p-0">
        <table class="w-full text-sm">
            <thead class="border-b border-neutral-200 text-left text-neutral-600">
                <tr>
                    <th class="px-4 py-3 font-medium">User</th>
                    <th class="px-4 py-3 font-medium">Role</th>
                    <th class="px-4 py-3 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
            @foreach (var a in Model.Assignments)
            {
                <tr>
                    <td class="px-4 py-3">@a.UserId</td>
                    <td class="px-4 py-3">@a.RoleKey</td>
                    <td class="px-4 py-3">
                        <div class="flex justify-end">
                            <form method="post" asp-page-handler="Revoke">
                                <input type="hidden" name="orgId" value="@Model.OrgId" />
                                <input type="hidden" name="userId" value="@a.UserId" />
                                <input type="hidden" name="roleKey" value="@a.RoleKey" />
                                <button type="submit" class="btn-danger btn-sm">Revoke</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <form method="post" asp-page-handler="Grant" class="flex max-w-2xl gap-2">
        <input type="hidden" name="orgId" value="@Model.OrgId" />
        <input type="text" name="userId" placeholder="User id" class="form-input" />
        <input type="text" name="roleKey" placeholder="Role key" class="form-input" />
        <button type="submit" class="btn-primary">Grant</button>
    </form>
}
