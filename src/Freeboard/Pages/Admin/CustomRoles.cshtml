@page "/admin/custom-roles"
@model Freeboard.Pages.Admin.CustomRolesModel
@{
    ViewData["Title"] = "Custom roles";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Custom roles</h1>
    <p class="mt-1 text-sm text-neutral-600">Design organisation-scoped roles from the allowed permissions.</p>
</div>

@if (Model.Notice is not null)
{
    <p class="notice mb-4 max-w-2xl">@Model.Notice</p>
}

<section class="mb-8 max-w-2xl">
    <h2 class="mb-4 text-lg font-semibold">New role</h2>
    <form method="post" asp-page-handler="Create" class="card space-y-4">
        <div class="space-y-1.5">
            <label class="form-label" for="roleKey">Role key</label>
            <input class="form-input" type="text" id="roleKey" name="roleKey" placeholder="custom:auditor" />
        </div>
        <div class="space-y-1.5">
            <label class="form-label" for="title">Title</label>
            <input class="form-input" type="text" id="title" name="title" />
        </div>
        <div class="space-y-1.5">
            <label class="form-label" for="description">Description</label>
            <input class="form-input" type="text" id="description" name="description" />
        </div>
        <fieldset class="space-y-2 rounded-md border border-neutral-200 p-4">
            <legend class="px-1 text-sm font-semibold">Permissions</legend>
            @foreach (var option in Model.PermissionOptions)
            {
                <label class="flex items-center gap-2 text-sm">
                    <input type="checkbox" name="permissionKeys" value="@option.PermissionKey" class="accent-brand" />
                    <span>@option.Label <span class="text-neutral-500">(@option.Group)</span></span>
                </label>
            }
        </fieldset>
        <button class="btn-primary" type="submit">Create role</button>
    </form>
</section>

<section class="max-w-3xl">
    <h2 class="mb-4 text-lg font-semibold">Existing roles</h2>
    @if (Model.Roles.Count == 0)
    {
        <p class="text-sm text-neutral-600">No custom roles yet.</p>
    }
    @foreach (var role in Model.Roles)
    {
        <div class="card mb-6">
            <form method="post" asp-page-handler="Update" class="space-y-4">
                <input type="hidden" name="roleKey" value="@role.Role.RoleKey" />
                <p class="font-mono text-sm">@role.Role.RoleKey</p>
                <div class="space-y-1.5">
                    <label class="form-label">Title
                        <input class="form-input mt-1" type="text" name="title" value="@role.Role.Title" />
                    </label>
                </div>
                <div class="space-y-1.5">
                    <label class="form-label">Description
                        <input class="form-input mt-1" type="text" name="description" value="@role.Role.Description" />
                    </label>
                </div>
                <fieldset class="space-y-2 rounded-md border border-neutral-200 p-4">
                    <legend class="px-1 text-sm font-semibold">Permissions</legend>
                    @foreach (var option in Model.PermissionOptions)
                    {
                        <label class="flex items-center gap-2 text-sm">
                            <input type="checkbox" name="permissionKeys" value="@option.PermissionKey" class="accent-brand"
                                   checked="@(role.PermissionKeys.Contains(option.PermissionKey))" />
                            <span>@option.Label <span class="text-neutral-500">(@option.Group)</span></span>
                        </label>
                    }
                </fieldset>
                <button class="btn-primary" type="submit">Save</button>
            </form>
            <form method="post" asp-page-handler="Delete" class="mt-3">
                <input type="hidden" name="roleKey" value="@role.Role.RoleKey" />
                <button class="btn-danger" type="submit">Delete</button>
            </form>
        </div>
    }
</section>
