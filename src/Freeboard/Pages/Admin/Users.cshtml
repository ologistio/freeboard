@page "/admin/users"
@model Freeboard.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users";
}
<div>
    <h1 class="text-2xl font-bold">Users</h1>

    @if (Model.Notice is not null)
    {
        <p class="my-3 text-[#b00020]">@Model.Notice</p>
    }
    @if (Model.InvitedEmail is not null)
    {
        <p class="success my-3" data-invite-confirmation>Invite sent to @Model.InvitedEmail, link expires in 7 days.</p>
    }
    @if (Model.InviteFailedEmail is not null)
    {
        <p class="my-3 text-[#b00020]">
            @Model.InviteFailedEmail was created, but the invite could not be sent. Use the
            reset-password action on that user to provide a credential. Re-creating the user will not work.
        </p>
    }

    <h2 class="mt-6 text-xl font-semibold">Create user</h2>
    <partial name="_ErrorSummary" model="ModelState" />
    <form class="space-y-2" method="post" asp-page-handler="Create">
        <label class="block font-semibold" for="email">Email</label>
        <input class="block w-full border border-neutral-400 p-2" type="email" id="email" name="email" autocomplete="off" />
        <label class="block font-semibold" for="name">Name</label>
        <input class="block w-full border border-neutral-400 p-2" type="text" id="name" name="name" autocomplete="off" />
        <label class="block font-semibold" for="global_role">Role</label>
        <select class="block w-full border border-neutral-400 p-2" id="global_role" name="global_role">
            <option value="member">member</option>
            <option value="admin">admin</option>
        </select>
        <fieldset class="border border-neutral-400 p-3">
            <legend class="px-1 font-semibold">Credential handoff</legend>
            <label class="font-semibold"><input type="radio" name="handoff" value="temp" checked /> Temporary password</label>
            @if (Model.EmailConfigured)
            {
                <label class="font-semibold"><input type="radio" name="handoff" value="invite" /> Email an invite link</label>
            }
            else
            {
                <label class="font-semibold"><input type="radio" name="handoff" value="invite" disabled /> Email an invite link</label>
                <span>Email is not configured; new users get a temporary password.</span>
            }
        </fieldset>
        <button class="cursor-pointer bg-[#215091] px-4 py-2 text-white" type="submit">Create user</button>
    </form>

    <h2 class="mt-6 text-xl font-semibold">Existing users</h2>
    <table class="w-full border-collapse">
        <thead>
            <tr>
                <th class="border-b border-neutral-300 px-2 py-1 text-left">Email</th>
                <th class="border-b border-neutral-300 px-2 py-1 text-left">Name</th>
                <th class="border-b border-neutral-300 px-2 py-1 text-left">Role</th>
                <th class="border-b border-neutral-300 px-2 py-1 text-left">Enabled</th>
                <th class="border-b border-neutral-300 px-2 py-1 text-left">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td class="border-b border-neutral-300 px-2 py-1 text-left">@user.Email</td>
                    <td class="border-b border-neutral-300 px-2 py-1 text-left">@user.Name</td>
                    <td class="border-b border-neutral-300 px-2 py-1 text-left">@user.GlobalRole</td>
                    <td class="border-b border-neutral-300 px-2 py-1 text-left">@(user.Enabled ? "yes" : "no")</td>
                    <td class="border-b border-neutral-300 px-2 py-1 text-left">
                        <form class="space-y-2" method="post" asp-page-handler="ResetPassword">
                            <input type="hidden" name="id" value="@user.Id" />
                            <button class="cursor-pointer bg-[#215091] px-4 py-2 text-white" type="submit">Reset password</button>
                        </form>
                        @if (user.Enabled)
                        {
                            <form class="space-y-2" method="post" asp-page-handler="Disable">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button class="cursor-pointer bg-[#215091] px-4 py-2 text-white" type="submit">Disable</button>
                            </form>
                        }
                        else
                        {
                            <form class="space-y-2" method="post" asp-page-handler="Enable">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button class="cursor-pointer bg-[#215091] px-4 py-2 text-white" type="submit">Enable</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
