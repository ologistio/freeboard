@page "/admin/users"
@model Freeboard.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Users</h1>
    <p class="mt-1 text-sm text-neutral-600">Create and manage user accounts.</p>
</div>

@if (Model.Notice is not null)
{
    <p class="notice-error mb-4 max-w-2xl">@Model.Notice</p>
}
@if (Model.InvitedEmail is not null)
{
    <p class="notice success mb-4 max-w-2xl" data-invite-confirmation>Invite sent to @Model.InvitedEmail, link expires in 7 days.</p>
}
@if (Model.InviteFailedEmail is not null)
{
    <p class="notice-error mb-4 max-w-2xl">
        @Model.InviteFailedEmail was created, but the invite could not be sent. Use the
        reset-password action on that user to provide a credential. Re-creating the user will not work.
    </p>
}

<div class="card mb-8 overflow-x-auto p-0">
    <table class="w-full text-sm">
        <thead class="border-b border-neutral-200 text-left text-neutral-600">
            <tr>
                <th class="px-4 py-3 font-medium">Email</th>
                <th class="px-4 py-3 font-medium">Name</th>
                <th class="px-4 py-3 font-medium">Role</th>
                <th class="px-4 py-3 font-medium">Status</th>
                <th class="px-4 py-3 font-medium text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td class="px-4 py-3">@user.Email</td>
                    <td class="px-4 py-3 text-neutral-600">@user.Name</td>
                    <td class="px-4 py-3">
                        @if (string.Equals(user.GlobalRole, "admin", StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="badge badge-brand capitalize">@user.GlobalRole</span>
                        }
                        else
                        {
                            <span class="badge badge-neutral capitalize">@user.GlobalRole</span>
                        }
                    </td>
                    <td class="px-4 py-3">
                        @if (user.Enabled)
                        {
                            <span class="badge badge-success">Enabled</span>
                        }
                        else
                        {
                            <span class="badge badge-neutral">Disabled</span>
                        }
                    </td>
                    <td class="px-4 py-3">
                        <div class="flex justify-end gap-2">
                            <form method="post" asp-page-handler="ResetPassword">
                                <input type="hidden" name="id" value="@user.Id" />
                                <button class="btn-secondary btn-sm" type="submit">Reset password</button>
                            </form>
                            @if (user.Enabled)
                            {
                                <form method="post" asp-page-handler="Disable">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn-danger btn-sm" type="submit">Disable</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Enable">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn-secondary btn-sm" type="submit">Enable</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card max-w-xl">
    <h2 class="mb-4 text-lg font-semibold">Create user</h2>
    <partial name="_ErrorSummary" model="ModelState" />
    <form class="space-y-4" method="post" asp-page-handler="Create">
        <div class="space-y-1.5">
            <label class="form-label" for="email">Email</label>
            <input class="form-input" type="email" id="email" name="email" autocomplete="off" placeholder="user@example.com" />
        </div>
        <div class="space-y-1.5">
            <label class="form-label" for="name">Name</label>
            <input class="form-input" type="text" id="name" name="name" autocomplete="off" placeholder="Full name" />
        </div>
        <div class="space-y-1.5">
            <label class="form-label" for="global_role">Role</label>
            <select class="form-input" id="global_role" name="global_role">
                <option value="member">Member</option>
                <option value="admin">Admin</option>
            </select>
        </div>
        <fieldset class="space-y-2 rounded-md border border-neutral-200 p-4">
            <legend class="px-1 text-sm font-semibold">Credential handoff</legend>
            <label class="flex items-center gap-2 text-sm"><input type="radio" name="handoff" value="temp" class="accent-brand" checked /> Temporary password</label>
            @if (Model.EmailConfigured)
            {
                <label class="flex items-center gap-2 text-sm"><input type="radio" name="handoff" value="invite" class="accent-brand" /> Email an invite link</label>
            }
            else
            {
                <label class="flex items-center gap-2 text-sm text-neutral-600"><input type="radio" name="handoff" value="invite" class="accent-brand" disabled /> Email an invite link</label>
                <p class="text-xs text-neutral-600">Email is not configured; new users get a temporary password.</p>
            }
        </fieldset>
        <button class="btn-primary" type="submit">Create user</button>
    </form>
</div>
