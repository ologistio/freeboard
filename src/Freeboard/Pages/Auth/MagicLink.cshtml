@page "/auth/magic-link"
@model Freeboard.Pages.Auth.MagicLinkModel
@{
    ViewData["Title"] = "Continue sign-in";
}
<h1 class="text-2xl font-bold">Continue sign-in</h1>
@if (!Model.CanComplete)
{
    <p class="my-3 text-[#b00020]">This sign-in link could not be used here. <a href="/login" class="text-[#215091] underline">Start again</a> in the browser where you began signing in.</p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <p class="my-3">Confirm to finish signing in.</p>
    <form method="post" class="space-y-2">
        <button type="submit" class="cursor-pointer bg-[#215091] px-4 py-2 text-white">Continue</button>
    </form>
}
