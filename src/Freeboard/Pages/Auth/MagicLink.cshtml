@page "/auth/magic-link"
@model Freeboard.Pages.Auth.MagicLinkModel
@{
    ViewData["Title"] = "Continue sign-in";
    Layout = "_AuthLayout";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Continue sign-in</h1>
    <p class="mt-1 text-sm text-neutral-600">Confirm to finish signing in.</p>
</div>
@if (!Model.CanComplete)
{
    <p class="notice-error">This sign-in link could not be used here. Start again in the browser where you began signing in.</p>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Back to sign in</a></p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post">
        <button type="submit" class="btn-primary w-full">Continue</button>
    </form>
}
