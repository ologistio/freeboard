@page "/reset-password"
@model Freeboard.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}
<h1>Reset password</h1>
@if (Model.Reset)
{
    <p class="success">Your password has been reset. <a href="/login">Sign in</a>.</p>
}
else if (!Model.HasToken)
{
    <p class="error">This reset link is expired or invalid. <a href="/forgot-password">Request a new one</a>.</p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post">
        <label for="new_password">New password</label>
        <input type="password" id="new_password" name="new_password" autocomplete="new-password" />
        <button type="submit">Reset password</button>
    </form>
}
