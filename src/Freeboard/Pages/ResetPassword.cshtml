@page "/reset-password"
@model Freeboard.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
}
<h1 class="text-2xl font-bold">Reset password</h1>
@if (Model.Reset)
{
    <p class="success my-3">Your password has been reset. <a href="/login" class="text-[#215091] underline">Sign in</a>.</p>
}
else if (!Model.HasToken)
{
    <p class="my-3 text-[#b00020]">This reset link is expired or invalid. <a href="/forgot-password" class="text-[#215091] underline">Request a new one</a>.</p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post" class="space-y-2">
        <label for="new_password" class="block font-semibold">New password</label>
        <input type="password" id="new_password" name="new_password" autocomplete="new-password" class="block w-full border border-neutral-400 p-2" />
        <button type="submit" class="cursor-pointer bg-[#215091] px-4 py-2 text-white">Reset password</button>
    </form>
}
