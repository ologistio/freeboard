@page "/reset-password"
@model Freeboard.Pages.ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
    Layout = "_AuthLayout";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Reset password</h1>
    <p class="mt-1 text-sm text-neutral-600">Choose a new password for your account.</p>
</div>
@if (Model.Reset)
{
    <p class="notice success">Your password has been reset.</p>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Sign in</a></p>
}
else if (!Model.HasToken)
{
    <p class="notice-error">This reset link is expired or invalid.</p>
    <p class="mt-6 text-center text-sm"><a href="/forgot-password" class="link">Request a new one</a></p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post" class="space-y-4">
        <div class="space-y-1.5">
            <label for="new_password" class="form-label">New password</label>
            <input type="password" id="new_password" name="new_password" autocomplete="new-password" placeholder="New password" autofocus class="form-input" />
        </div>
        <button type="submit" class="btn-primary w-full">Reset password</button>
    </form>
}
