@page "/setup"
@model Freeboard.Pages.SetupModel
@{
    ViewData["Title"] = "First-admin setup";
    Layout = "_AuthLayout";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">First-admin setup</h1>
    <p class="mt-1 text-sm text-neutral-600">Create the first administrator for this Freeboard instance.</p>
</div>
@if (Model.AlreadyInitialized)
{
    <p class="notice">This Freeboard instance is already set up.</p>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Sign in</a></p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post" class="space-y-4">
        <div class="space-y-1.5">
            <label for="name" class="form-label">Name</label>
            <input type="text" id="name" name="name" autocomplete="name" placeholder="Your name" autofocus class="form-input" />
        </div>
        <div class="space-y-1.5">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" autocomplete="username" placeholder="you@example.com" class="form-input" />
        </div>
        <div class="space-y-1.5">
            <label for="password" class="form-label">Password</label>
            <input type="password" id="password" name="password" autocomplete="new-password" placeholder="Choose a password" class="form-input" />
        </div>
        <div class="space-y-1.5">
            <label for="bootstrap_secret" class="form-label">Bootstrap secret</label>
            <input type="password" id="bootstrap_secret" name="bootstrap_secret" autocomplete="off" placeholder="From your server configuration" class="form-input" />
        </div>
        <button type="submit" class="btn-primary w-full">Create admin</button>
    </form>
}
