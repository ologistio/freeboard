@page "/forgot-password"
@model Freeboard.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
}
<h1 class="text-2xl font-bold">Forgot password</h1>
@if (Model.Submitted)
{
    <p class="success my-3">If an account exists for that email, we have sent a password-reset link.</p>
}
else
{
    <form method="post" class="space-y-2">
        <label for="email" class="block font-semibold">Email</label>
        <input type="email" id="email" name="email" autocomplete="username" class="block w-full border border-neutral-400 p-2" />
        <button type="submit" class="cursor-pointer bg-[#215091] px-4 py-2 text-white">Send reset link</button>
    </form>
}
<p class="my-3"><a href="/login" class="text-[#215091] underline">Back to sign in</a></p>
