@page "/forgot-password"
@model Freeboard.Pages.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
    Layout = "_AuthLayout";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Forgot password</h1>
    <p class="mt-1 text-sm text-neutral-600">Enter your email and we'll send a reset link.</p>
</div>
@if (Model.Submitted)
{
    <p class="notice success">If an account exists for that email, we have sent a password-reset link.</p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post" class="space-y-4">
        <div class="space-y-1.5">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" autocomplete="username" placeholder="you@example.com" autofocus class="form-input" />
        </div>
        <button type="submit" class="btn-primary w-full">Send reset link</button>
    </form>
}
<p class="mt-6 text-center text-sm">
    <a href="/login" class="link">Back to sign in</a>
</p>
