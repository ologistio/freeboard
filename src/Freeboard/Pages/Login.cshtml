@page
@model Freeboard.Pages.LoginModel
@{
    ViewData["Title"] = "Sign in";
    Layout = "_AuthLayout";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Sign in</h1>
    <p class="mt-1 text-sm text-neutral-600">Welcome back. Sign in to your Freeboard account.</p>
</div>
<partial name="_ErrorSummary" model="ModelState" />
<form method="post" class="space-y-4">
    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
    <div class="space-y-1.5">
        <label for="email" class="form-label">Email</label>
        <input type="email" id="email" name="email" autocomplete="username" placeholder="you@example.com" autofocus class="form-input" />
    </div>
    <div class="space-y-1.5">
        <label for="password" class="form-label">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" placeholder="Your password" class="form-input" />
    </div>
    <button type="submit" class="btn-primary w-full">Sign in</button>
</form>
<p class="mt-6 text-center text-sm">
    <a href="/forgot-password" class="link">Forgot your password?</a>
</p>
