@page "/login/mfa/totp"
@model Freeboard.Pages.Login.Mfa.TotpModel
@{
    ViewData["Title"] = "Authenticator code";
    Layout = "_AuthLayout";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Authenticator code</h1>
    <p class="mt-1 text-sm text-neutral-600">Enter the 6-digit code from your authenticator app.</p>
</div>
@if (!Model.HasPendingChallenge)
{
    <p class="notice-error">Your sign-in could not be continued.</p>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Start again</a></p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post" class="space-y-4">
        <div class="space-y-1.5">
            <label for="code" class="form-label">Code</label>
            <input type="text" id="code" name="code" inputmode="numeric" autocomplete="one-time-code" placeholder="123456" autofocus class="form-input text-center tracking-[0.4em]" />
        </div>
        <button type="submit" class="btn-primary w-full">Verify</button>
    </form>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Start again</a></p>
}
