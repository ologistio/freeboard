@page "/login/mfa/totp"
@model Freeboard.Pages.Login.Mfa.TotpModel
@{
    ViewData["Title"] = "Authenticator code";
}
<h1 class="text-2xl font-bold">Authenticator code</h1>
@if (!Model.HasPendingChallenge)
{
    <p class="my-3 text-[#b00020]">Your sign-in could not be continued. <a href="/login" class="text-[#215091] underline">Start again</a>.</p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post" class="space-y-2">
        <label for="code" class="block font-semibold">Enter the 6-digit code from your authenticator app</label>
        <input type="text" id="code" name="code" inputmode="numeric" autocomplete="one-time-code" class="block w-full border border-neutral-400 p-2" />
        <button type="submit" class="cursor-pointer bg-[#215091] px-4 py-2 text-white">Verify</button>
    </form>
}
