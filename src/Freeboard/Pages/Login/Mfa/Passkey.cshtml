@page "/login/mfa/passkey"
@model Freeboard.Pages.Login.Mfa.PasskeyModel
@{
    ViewData["Title"] = "Use your passkey";
    Layout = "_AuthLayout";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Use your passkey</h1>
    <p class="mt-1 text-sm text-neutral-600">Confirm with your passkey to finish signing in.</p>
</div>
@if (!Model.HasPendingChallenge || Model.OptionsJson is null)
{
    <p class="notice-error">Your sign-in could not be continued.</p>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Start again</a></p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <div data-passkey-assert
         data-action="/login/mfa/passkey"
         data-antiforgery="@Model.AntiforgeryToken"
         data-options="@Model.OptionsJson">
        <button type="button" data-passkey-go class="btn-primary w-full">Use passkey</button>
    </div>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Start again</a></p>
    <script src="~/js/passkey.js"></script>
}
