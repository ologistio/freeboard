@page "/login/mfa/magic-link"
@model Freeboard.Pages.Login.Mfa.MagicLinkModel
@{
    ViewData["Title"] = "Email a sign-in link";
    Layout = "_AuthLayout";
}
<div class="mb-6">
    <h1 class="text-2xl font-bold">Email a sign-in link</h1>
    <p class="mt-1 text-sm text-neutral-500">We'll email you a link to finish signing in.</p>
</div>
@if (Model.Sent)
{
    <p class="notice">If your account can use a sign-in link, we have sent one. Check your email and open the link in this browser to continue.</p>
}
else if (!Model.HasPendingChallenge)
{
    <p class="notice-error">Your sign-in could not be continued.</p>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Start again</a></p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post">
        <button type="submit" class="btn-primary w-full">Email me a sign-in link</button>
    </form>
    <p class="mt-6 text-center text-sm"><a href="/login" class="link">Start again</a></p>
}
