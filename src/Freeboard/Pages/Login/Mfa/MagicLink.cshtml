@page "/login/mfa/magic-link"
@model Freeboard.Pages.Login.Mfa.MagicLinkModel
@{
    ViewData["Title"] = "Email a sign-in link";
}
<h1>Email a sign-in link</h1>
@if (Model.Sent)
{
    <p class="success">If your account can use a sign-in link, we have sent one. Check your email and open the link in this browser to continue.</p>
}
else if (!Model.HasPendingChallenge)
{
    <p class="error">Your sign-in could not be continued. <a href="/login">Start again</a>.</p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <form method="post">
        <button type="submit">Email me a sign-in link</button>
    </form>
}
