@page "/compliance/statement-of-applicability"
@using Freeboard.Compliance
@model Freeboard.Pages.Compliance.StatementOfApplicabilityModel
@{
    ViewData["Title"] = "Statement of Applicability";
}
<div class="soa">
    <h1>Statement of Applicability</h1>

    @if (Model.StoreUnreachable)
    {
        <p class="error">The compliance store could not be reached. Check the database connection.</p>
    }
    else
    {
        <form method="get">
            <label for="standard">Standard</label>
            <select id="standard" name="standard" onchange="this.form.submit()">
                <option value="">Choose a standard</option>
                @foreach (var standard in Model.Standards)
                {
                    if (string.Equals(standard.Id, Model.StandardId, StringComparison.Ordinal))
                    {
                        <option value="@standard.Id" selected>@standard.Title</option>
                    }
                    else
                    {
                        <option value="@standard.Id">@standard.Title</option>
                    }
                }
            </select>
            <noscript><button type="submit">Show</button></noscript>
        </form>

        @if (Model.StandardId is not null)
        {
            <table class="soa-nodes" data-standard="@Model.StandardId">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Title</th>
                        <th>Disposition</th>
                        <th>Resolution</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var node in Model.Nodes)
                    {
                        <tr data-node-id="@node.Id">
                            <td>@node.Id</td>
                            <td>@node.Title</td>
                            <td>@Freeboard.Pages.Compliance.StatementOfApplicabilityModel.DispositionLabel(node)</td>
                            <td>@node.Resolution.ToWireValue()</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>
