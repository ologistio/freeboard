@page "/account/mfa/recovery-codes"
@model Freeboard.Pages.Account.Mfa.RecoveryCodesModel
@{
    ViewData["Title"] = "Recovery codes";
}
<h1 class="text-2xl font-bold">Recovery codes</h1>
@if (Model.RecoveryCodes is { Count: > 0 })
{
    <p class="success my-3">Save these recovery codes now - they are shown only once. Each code works once if you lose your other factors.</p>
    <ul class="my-2 list-disc pl-5">
        @foreach (var code in Model.RecoveryCodes)
        {
            <li>@code</li>
        }
    </ul>
}
else
{
    <p class="my-3">There are no recovery codes to show. They are displayed only once, right after they are generated.</p>
}
<p class="my-3"><a class="text-[#215091] underline" href="/account/mfa">Back to security settings</a></p>
