@page "/account/mfa"
@model Freeboard.Pages.Account.Mfa.IndexModel
@{
    ViewData["Title"] = "Security settings";
}
<h1 class="text-2xl font-bold">Security settings</h1>

<section class="my-6">
    <h2 class="mt-6 text-xl font-semibold">Authenticator app (TOTP)</h2>
    @if (Model.TotpEnrolled)
    {
        <p class="my-3">An authenticator app is set up.</p>
        <form class="space-y-2" method="post" action="/account/mfa/totp/remove" asp-antiforgery="true">
            <button class="cursor-pointer bg-[#215091] px-4 py-2 text-white" type="submit">Remove authenticator</button>
        </form>
    }
    else
    {
        <p class="my-3">No authenticator app is set up.</p>
        <p class="my-3"><a class="text-[#215091] underline" href="/account/mfa/totp">Set up an authenticator app</a></p>
    }
</section>

<section class="my-6">
    <h2 class="mt-6 text-xl font-semibold">Passkeys</h2>
    @if (Model.Passkeys.Count > 0)
    {
        <ul class="my-2 list-disc pl-5">
            @foreach (var passkey in Model.Passkeys)
            {
                <li>
                    <span>@(string.IsNullOrEmpty(passkey.Nickname) ? "Passkey" : passkey.Nickname)</span>
                    <form class="space-y-2" method="post" action="/account/mfa/passkey/remove" asp-antiforgery="true">
                        <input type="hidden" name="id" value="@passkey.Id" />
                        <button class="cursor-pointer bg-[#215091] px-4 py-2 text-white" type="submit">Remove</button>
                    </form>
                </li>
            }
        </ul>
    }
    else
    {
        <p class="my-3">No passkeys are registered.</p>
    }
    <p class="my-3"><a class="text-[#215091] underline" href="/account/mfa/passkey">Add a passkey</a></p>
</section>

<section class="my-6">
    <h2 class="mt-6 text-xl font-semibold">Recovery codes</h2>
    <p class="my-3">@Model.RecoveryCodesRemaining recovery code(s) remaining.</p>
    <form class="space-y-2" method="post" action="/account/mfa/recovery" asp-antiforgery="true">
        <button class="cursor-pointer bg-[#215091] px-4 py-2 text-white" type="submit">Generate new recovery codes</button>
    </form>
</section>

<p class="my-3"><a class="text-[#215091] underline" href="/account">Back to account</a></p>
