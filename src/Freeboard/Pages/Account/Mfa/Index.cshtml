@page "/account/mfa"
@model Freeboard.Pages.Account.Mfa.IndexModel
@{
    ViewData["Title"] = "Security settings";
}
<partial name="_AccountNav" />
<div class="mb-6">
    <h1 class="text-2xl font-bold">Security</h1>
    <p class="mt-1 text-sm text-neutral-500">Manage the factors used to protect your account.</p>
</div>

<div class="max-w-2xl space-y-4">
    <div class="card">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="font-semibold">Authenticator app</h2>
                <p class="mt-1 text-sm text-neutral-500">
                    @(Model.TotpEnrolled ? "An authenticator app is set up." : "Use a one-time code from an app as a second factor.")
                </p>
            </div>
            @if (Model.TotpEnrolled)
            {
                <form method="post" action="/account/mfa/totp/remove" asp-antiforgery="true">
                    <button class="btn-danger" type="submit">Remove</button>
                </form>
            }
            else
            {
                <a class="btn-primary" href="/account/mfa/totp">Set up</a>
            }
        </div>
    </div>

    <div class="card">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="font-semibold">Passkeys</h2>
                <p class="mt-1 text-sm text-neutral-500">Sign in with a device passkey or security key.</p>
            </div>
            <a class="btn-primary" href="/account/mfa/passkey">Add passkey</a>
        </div>
        @if (Model.Passkeys.Count > 0)
        {
            <ul class="mt-4 divide-y divide-neutral-100 border-t border-neutral-100">
                @foreach (var passkey in Model.Passkeys)
                {
                    <li class="flex items-center justify-between gap-4 py-3">
                        <span>@(string.IsNullOrEmpty(passkey.Nickname) ? "Passkey" : passkey.Nickname)</span>
                        <form method="post" action="/account/mfa/passkey/remove" asp-antiforgery="true">
                            <input type="hidden" name="id" value="@passkey.Id" />
                            <button class="btn-danger" type="submit">Remove</button>
                        </form>
                    </li>
                }
            </ul>
        }
    </div>

    <div class="card">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="font-semibold">Recovery codes</h2>
                <p class="mt-1 text-sm text-neutral-500">
                    @Model.RecoveryCodesRemaining remaining. One-time codes to sign in if you lose your other factors.
                </p>
            </div>
            <form method="post" action="/account/mfa/recovery" asp-antiforgery="true">
                <button class="btn-secondary" type="submit">Generate new</button>
            </form>
        </div>
    </div>
</div>
