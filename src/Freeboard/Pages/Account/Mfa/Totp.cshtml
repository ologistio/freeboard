@page "/account/mfa/totp"
@model Freeboard.Pages.Account.Mfa.TotpModel
@{
    ViewData["Title"] = "Set up an authenticator app";
}
<h1>Set up an authenticator app</h1>
@if (Model.ProvisioningUri is null)
{
    <p>Set up an authenticator app to use a one-time code as a second factor.</p>
    <form method="post" asp-page-handler="Begin">
        <button type="submit">Set up authenticator app</button>
    </form>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <p>Add this to your authenticator app, then enter the 6-digit code it shows to confirm.</p>
    <p class="provisioning-uri"><code>@Model.ProvisioningUri</code></p>
    <form method="post">
        <label for="code">Confirmation code</label>
        <input type="text" id="code" name="code" inputmode="numeric" autocomplete="one-time-code" />
        <button type="submit">Confirm</button>
    </form>
}
<p><a href="/account/mfa">Back to security settings</a></p>
