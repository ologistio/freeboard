@page "/account/mfa/passkey"
@model Freeboard.Pages.Account.Mfa.PasskeyModel
@{
    ViewData["Title"] = "Add a passkey";
    ViewData["NavGroup"] = "Platform";
    ViewData["BreadcrumbParent"] = "Account";
    ViewData["BreadcrumbParentHref"] = "/account";
}
<partial name="_AccountNav" />
<div class="mb-6">
    <h1 class="text-2xl font-bold">Add a passkey</h1>
    <p class="mt-1 text-sm text-neutral-600">Register a device passkey or security key.</p>
</div>
@if (Model.WebAuthnUnconfigured)
{
    <p class="notice-error max-w-md">Passkeys are not available on this server.</p>
}
else if (Model.OptionsJson is null)
{
    <p class="notice-error max-w-md">Could not start passkey registration. <a class="link" href="/account/mfa">Go back</a> and try again.</p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <div class="card max-w-md space-y-4"
         data-passkey-register
         data-action="/account/mfa/passkey"
         data-antiforgery="@Model.AntiforgeryToken"
         data-options="@Model.OptionsJson"
         data-correlation="@Model.Correlation">
        <div class="space-y-1.5">
            <label class="form-label" for="nickname">Passkey name (optional)</label>
            <input class="form-input" type="text" id="nickname" data-nickname />
        </div>
        <button class="btn-primary" type="button" data-passkey-go>Add passkey</button>
    </div>
    <script src="~/js/passkey.js"></script>
}
<p class="mt-6 text-sm"><a class="link" href="/account/mfa">Back to security</a></p>
