@page "/account/mfa/passkey"
@model Freeboard.Pages.Account.Mfa.PasskeyModel
@{
    ViewData["Title"] = "Add a passkey";
}
<h1 class="text-2xl font-bold">Add a passkey</h1>
@if (Model.WebAuthnUnconfigured)
{
    <p class="my-3 text-[#b00020]">Passkeys are not available on this server.</p>
}
else if (Model.OptionsJson is null)
{
    <p class="my-3 text-[#b00020]">Could not start passkey registration. <a class="text-[#215091] underline" href="/account/mfa">Go back</a> and try again.</p>
}
else
{
    <partial name="_ErrorSummary" model="ModelState" />
    <div data-passkey-register
         data-action="/account/mfa/passkey"
         data-antiforgery="@Model.AntiforgeryToken"
         data-options="@Model.OptionsJson"
         data-correlation="@Model.Correlation">
        <label class="block font-semibold" for="nickname">Passkey name (optional)</label>
        <input class="block w-full border border-neutral-400 p-2" type="text" id="nickname" data-nickname />
        <button class="cursor-pointer bg-[#215091] px-4 py-2 text-white" type="button" data-passkey-go>Add passkey</button>
    </div>
    <script src="~/js/passkey.js"></script>
}
