@page "/account/sessions"
@model Freeboard.Pages.Account.SessionsModel
@{
    ViewData["Title"] = "Active sessions";
    ViewData["NavGroup"] = "Platform";
    ViewData["BreadcrumbParent"] = "Account";
    ViewData["BreadcrumbParentHref"] = "/account";
}
<partial name="_AccountNav" />
<div class="mb-6">
    <h1 class="text-2xl font-bold">Active sessions</h1>
    <p class="mt-1 text-sm text-muted">Devices and browsers currently signed in to your account.</p>
</div>
@if (Model.Sessions.Count == 0)
{
    <p class="notice max-w-md">No active sessions.</p>
}
else
{
    <div class="card overflow-x-auto p-0">
        <table class="w-full text-sm">
            <thead class="border-b border-neutral-200 text-left text-muted">
                <tr>
                    <th class="px-4 py-3 font-medium">Session</th>
                    <th class="px-4 py-3 font-medium">Signed in</th>
                    <th class="px-4 py-3 font-medium">Last seen</th>
                    <th class="px-4 py-3 font-medium">Expires</th>
                    <th class="px-4 py-3 font-medium"><span class="sr-only">Actions</span></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
            @foreach (var s in Model.Sessions)
            {
                <tr>
                    <td class="px-4 py-3">
                        <span class="font-mono text-xs text-muted">@s.Id</span>
                        @if (s.IsCurrent)
                        {
                            <span class="ml-1 badge badge-brand">This session</span>
                        }
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-muted">@s.CreatedAt.ToString("u")</td>
                    <td class="px-4 py-3 whitespace-nowrap text-muted">@(s.LastSeenAt?.ToString("u") ?? "-")</td>
                    <td class="px-4 py-3 whitespace-nowrap text-muted">@s.ExpiresAt.ToString("u")</td>
                    <td class="px-4 py-3 text-right">
                        <form method="post" action="/account/sessions/revoke" asp-antiforgery="true">
                            <input type="hidden" name="sessionId" value="@s.Id" />
                            <button type="submit" class="btn-danger">Revoke</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <form method="post" action="/account/sessions/revoke" asp-antiforgery="true" class="mt-4">
        <input type="hidden" name="all" value="true" />
        <button type="submit" class="btn-danger">Sign out everywhere</button>
    </form>
}
