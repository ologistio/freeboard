@page "/account/password/change"
@model Freeboard.Pages.Account.Password.ChangeModel
@{
    ViewData["Title"] = "Change password";
}
<partial name="_AccountNav" />
<div class="mb-6">
    <h1 class="text-2xl font-bold">Change password</h1>
    <p class="mt-1 text-sm text-neutral-500">Update the password you use to sign in.</p>
</div>
@if (Model.Changed)
{
    <p class="notice mb-4 max-w-md">Your password has been changed.</p>
}
<partial name="_ErrorSummary" model="ModelState" />
<form method="post" class="card max-w-md space-y-4">
    <div class="space-y-1.5">
        <label for="old_password" class="form-label">Current password</label>
        <input type="password" id="old_password" name="old_password" autocomplete="current-password" class="form-input" />
    </div>
    <div class="space-y-1.5">
        <label for="new_password" class="form-label">New password</label>
        <input type="password" id="new_password" name="new_password" autocomplete="new-password" class="form-input" />
    </div>
    <button type="submit" class="btn-primary">Change password</button>
</form>
