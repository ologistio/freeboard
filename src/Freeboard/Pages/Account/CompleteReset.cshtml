@page "/account/complete-reset"
@model Freeboard.Pages.Account.CompleteResetModel
@{
    ViewData["Title"] = "Set a new password";
}
<h1 class="text-2xl font-bold">Set a new password</h1>
<p class="my-3">You must set a new password before continuing.</p>
<partial name="_ErrorSummary" model="ModelState" />
<form method="post" class="space-y-2">
    <label for="new_password" class="block font-semibold">New password</label>
    <input type="password" id="new_password" name="new_password" autocomplete="new-password" class="block w-full border border-neutral-400 p-2" />
    <button type="submit" class="cursor-pointer bg-[#215091] px-4 py-2 text-white">Set password</button>
</form>
